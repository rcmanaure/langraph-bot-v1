# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ragbot:ragbot@postgres:5432/ragbot

# Connection pool sizing (total ≤20 connections; PG default max_connections=100)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
# AsyncPostgresSaver internal pool (LangGraph checkpointer)
DB_CHECKPOINT_POOL_SIZE=5

DB_USER=ragbot
DB_PASSWORD=ragbot
DB_NAME=ragbot

# ── LangGraph / LangChain ────────────────────────────────────────────────────
# LangSmith observability (set to false to disable tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=langraph-bot-v1

# PII in LangSmith traces — set both to true when first EU/LATAM tenant onboards
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false

# ── Chat LLM (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/free
OPENAI_FALLBACK_MODEL=deepseek/deepseek-v4-flash

# Embedding model — routed through OpenRouter (same key, override if using a different provider)
EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_BASE_URL=   # defaults to OPENROUTER_BASE_URL
# EMBEDDING_API_KEY=    # defaults to OPENROUTER_API_KEY

# ── Message / context window ──────────────────────────────────────────────────
# Max tokens to keep in messages history (trim_messages applied at validate node)
HISTORY_MAX_TOKENS=8000
# Max tokens for retrieved chunks injected into generate prompt
RETRIEVAL_MAX_TOKENS=3000

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=...
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-32-chars-minimum
FERNET_KEY=...

# CSRF guard — must be non-empty in production
CSRF_SECRET=change-me

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Traefik ───────────────────────────────────────────────────────────────────
TRAEFIK_HOST=bot.yourdomain.com

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── STT (Groq Whisper, optional) ─────────────────────────────────────────────
GROQ_API_KEY=
